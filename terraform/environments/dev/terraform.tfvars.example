aws_region = "us-east-1"
acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/REPLACE_ME"

# Optional: email for SNS alarm notifications (Terraform will create a subscription).
sns_alarm_email = "you@example.com"

# Required for automatic MySQL secret rotation (recommended for prod).
# Leave empty if you will skip rotation in this sandbox.
secrets_rotation_lambda_arn = "arn:aws:lambda:us-east-1:123456789012:function:REPLACE_ME"

instance_type = "t3.micro"
asg_min_size = 1
asg_max_size = 1
asg_desired_capacity = 1

# Low-cost settings (reduce HA)
rds_multi_az = false
rds_create_read_replica = false
redis_automatic_failover_enabled = false
enable_waf = false

